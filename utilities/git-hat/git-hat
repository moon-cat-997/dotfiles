#!/bin/bash
set -euo pipefail
shopt -s nullglob   # незамэтченный glob раскрывается в пустоту, а не в литерал '*'

# resolve_symlink <path> — разыменовывает цепочку симлинков (~/bin/git-hat,
# ~/bin/hat → реальный файл в репо), иначе SCRIPT_DIR указал бы на ~/bin, где
# нет personas/. Раньше здесь был `readlink -f`, но -f — GNU-расширение,
# в BSD/macOS его нет; `readlink` без флагов есть везде, поэтому идём вручную.
resolve_symlink() {
  local src="$1" dir
  while [ -L "$src" ]; do
    dir=$(cd -P "$(dirname "$src")" && pwd)
    src=$(readlink "$src")
    case "$src" in
      /*) ;;                  # абсолютный target — как есть
      *)  src="$dir/$src" ;;  # относительный — от каталога симлинка
    esac
  done
  printf '%s\n' "$src"
}

SCRIPT_DIR="$(cd -P "$(dirname "$(resolve_symlink "${BASH_SOURCE[0]}")")" && pwd)"
PERSONAS_DIR="$SCRIPT_DIR/personas"

# normalize_path <path> — переносимая замена `realpath -m` (флаг -m есть только
# в GNU coreutils; в BSD/macOS realpath его не знает). Как и -m, не требует
# существования пути: существующий каталог разыменовываем через `cd -P`,
# несуществующий — схлопываем лексически ('.', '..', пустые сегменты).
normalize_path() {
  local p="$1" out="" part rest

  case "$p" in
    /*) ;;                # уже абсолютный
    *)  p="$PWD/$p" ;;    # относительный — от текущего каталога
  esac

  if [ -d "$p" ]; then
    (cd -P "$p" 2>/dev/null && pwd) && return 0
  fi

  # Лексическая нормализация. Разбор через ${var%%/*} вместо `for x in $p`:
  # незакавыченное расширение попало бы под globbing (в скрипте включён nullglob).
  rest="${p#/}"
  while [ -n "$rest" ]; do
    part="${rest%%/*}"
    if [ "$part" = "$rest" ]; then rest=""; else rest="${rest#*/}"; fi
    case "$part" in
      ''|.) ;;                      # пустой сегмент ('//') и '.' — пропустить
      ..)   out="${out%/*}" ;;      # подняться на уровень вверх
      *)    out="$out/$part" ;;
    esac
  done
  printf '%s\n' "${out:-/}"
}

usage() {
  cat >&2 <<'EOF'
Usage: git-hat <command> [args]

Commands:
  clone <url>              clone repo using persona for current dir
  remote-add <url> [name]  add a remote (default 'origin') under the dir's persona alias
  adopt                    rewrite GitHub remotes of the current repo to its dir's persona
  whoami                   show persona for current dir
  add <name>               create a new persona interactively (conf + sync)
  remove <name>            delete a persona (asks confirmation; dir is kept)
  sync                     regenerate ssh/git config from personas/ (creates persona dirs)
  keygen                   generate missing persona ssh keys, offer upload via gh
  doctor                   check machine readiness: gh, keys, dirs, ssh auth per persona
EOF
}

list_personas() {
  local f
  for f in "$PERSONAS_DIR"/*.conf; do
    basename "$f" .conf
  done
}

load_persona() {
  local name="$1"
  local file="$PERSONAS_DIR/$name.conf"

  if [ ! -f "$file" ]; then 
    echo "Unknown persona: $name" >&2
    return 1
  fi

  source "$file"
}

# persona_for_path <path> — печатает имя персоны, в чьей DIR лежит путь.
# Совпадение по границе '/', при нескольких — выигрывает самое длинное DIR.
persona_for_path() {
  local path
  path=$(normalize_path "$1")         # нормализуем входной путь

  local best_name="" best_len=0       # лучшее совпадение пока пустое

  local name dir
  for name in $(list_personas); do
    load_persona "$name"              # подгрузит DIR этой персоны из .conf
    dir=$(normalize_path "$DIR")      # нормализуем её каталог

    # path внутри dir (или равен) — по границе '/'
    if [ "$path" = "$dir" ] || [ "${path#"$dir"/}" != "$path" ]; then
      # оставить, только если этот dir длиннее прежнего лучшего
      if [ "${#dir}" -gt "$best_len" ]; then
        best_name="$name"
        best_len="${#dir}"
      fi
    fi
  done

  # Явный возврат: нашли → печать + успех; не нашли → код 1 (сигнал "нет персоны")
  if [ -n "$best_name" ]; then
    echo "$best_name"
  else
    return 1
  fi
}

# cmd_whoami [path] — печатает персону и её identity для пути (по умолчанию — $PWD).
# Живой GitHub-логин ключа здесь не показываем (это сетевой ssh-тест) — см. 'hat doctor'.
cmd_whoami() {
  local path="${1:-$PWD}"          # аргумент, а если нет — $PWD
  local persona
  if persona=$(persona_for_path "$path"); then
    load_persona "$persona"        # persona_for_path оставляет вары ПОСЛЕДНЕЙ проверенной персоны
    echo "$persona — $NAME <$EMAIL> (git@github-$persona)"
  else
    echo "No persona for: $path" >&2
    return 1
  fi
}

# ask <prompt> [default] — читает значение (пустой ввод → default, а без
# default — ошибка). Конфы персон — sourced shell, поэтому символы, ломающие
# source ($ " ` \), запрещены; '~' разрешён и нормализуется в to_home_var.
ask() {
  local prompt="$1" default="${2:-}" val bad='["\\$`]'
  read -rp "$prompt" val || val=""
  val="${val:-$default}"
  if [ -z "$val" ]; then
    echo "Value required, aborting." >&2
    return 1
  fi
  if [[ "$val" =~ $bad ]]; then
    echo "Forbidden characters in value (\" \\ \$ \`): $val" >&2
    return 1
  fi
  echo "$val"
}

# to_home_var <path> — переносимая форма пути: домашний каталог → литеральная
# строка '$HOME' (раскроется при source на любой машине, как в существующих конфах)
to_home_var() {
  local p="$1"
  case "$p" in
    "~")       printf '$HOME\n' ;;
    "~/"*)     printf '$HOME/%s\n' "${p#\~/}" ;;
    "$HOME"/*) printf '$HOME/%s\n' "${p#"$HOME"/}" ;;
    *)         printf '%s\n' "$p" ;;
  esac
}

# cmd_add <name> — интерактивно создаёт personas/<name>.conf и запускает sync.
# Дефолты подставляются из имени; ключа после создания ещё нет — предлагаем
# сразу hat keygen (он пропускает персоны с существующими ключами).
cmd_add() {
  local name="${1:-}"
  if [ -z "$name" ]; then
    echo "Usage: git-hat add <name>" >&2
    return 1
  fi

  # имя станет ssh-алиасом github-<name> и именем файла — только [a-z0-9-]
  if [[ ! "$name" =~ ^[a-z0-9][a-z0-9-]*$ ]]; then
    echo "Invalid persona name: '$name' (use lowercase letters, digits, '-')" >&2
    return 1
  fi

  local file="$PERSONAS_DIR/$name.conf"
  if [ -f "$file" ]; then
    echo "Persona already exists: $file" >&2
    return 1
  fi

  echo "Creating persona '$name' (ssh alias: github-$name)"
  local git_name git_email key dir
  git_name=$(ask  "  git user.name: ")  || return 1
  git_email=$(ask "  git user.email: ") || return 1
  key=$(ask "  ssh key [~/.ssh/id_hat_$name]: " "~/.ssh/id_hat_$name") || return 1
  dir=$(ask "  root dir [~/Projects/$name]: "  "~/Projects/$name")     || return 1
  key=$(to_home_var "$key")
  dir=$(to_home_var "$dir")

  # предупредить о вложенности с DIR других персон: longest-prefix в
  # persona_for_path разрулит конфликт, но затенение должно быть осознанным
  local dir_abs other other_abs
  dir_abs=$(normalize_path "${dir/#\$HOME/$HOME}")
  for other in $(list_personas); do
    load_persona "$other"
    other_abs=$(normalize_path "$DIR")
    if [ "$dir_abs" = "$other_abs" ] \
       || [ "${dir_abs#"$other_abs"/}" != "$dir_abs" ] \
       || [ "${other_abs#"$dir_abs"/}" != "$other_abs" ]; then
      echo "⚠ dir overlaps persona '$other' ($other_abs) — longest DIR wins inside the overlap"
    fi
  done

  {
    printf 'NAME="%s"\n'  "$git_name"
    printf 'EMAIL="%s"\n' "$git_email"
    printf 'KEY="%s"\n'   "$key"
    printf 'DIR="%s"\n'   "$dir"
  } > "$file"
  echo "✔ created $file"

  cmd_sync

  local ans
  read -rp "Generate missing SSH keys now (hat keygen)? [Y/n] " ans || ans=""
  if [[ "$ans" =~ ^[Nn]$ ]]; then
    echo "Run 'hat keygen' later, then 'hat doctor' to verify."
  else
    cmd_keygen
  fi
}

# cmd_remove <name> — удаляет персону: preflight-отчёт, подтверждение, удаление
# .conf + sync (sync сам вычищает generated-конфиги удалённых персон).
# DIR и его содержимое не трогаем никогда; ключ — только по явному согласию.
cmd_remove() {
  local name="${1:-}"
  if [ -z "$name" ]; then
    echo "Usage: git-hat remove <name>" >&2
    return 1
  fi

  if ! load_persona "$name"; then
    echo "Available personas: $(list_personas | tr '\n' ' ')" >&2
    return 1
  fi
  # зафиксировать поля персоны в локалы до любых дальнейших load_persona
  local p_dir p_key p_name p_email
  p_dir=$(normalize_path "$DIR"); p_key="$KEY"; p_name="$NAME"; p_email="$EMAIL"

  echo "Removing persona '$name' — $p_name <$p_email>"
  echo "  conf: $PERSONAS_DIR/$name.conf (will be deleted)"
  echo "  dir:  $p_dir (kept — never touched)"
  echo "  key:  $p_key (kept unless you agree below)"

  # preflight: репозитории в DIR с remote'ами на исчезающий алиас github-<name>
  local gitdir repo broken=0
  if [ -d "$p_dir" ]; then
    while IFS= read -r gitdir; do
      repo="${gitdir%/.git}"
      if git -C "$repo" remote -v 2>/dev/null | grep -q "github-$name[:/]"; then
        [ "$broken" -eq 0 ] && echo "⚠ repos with remotes on 'github-$name' (they will BREAK after removal):"
        echo "    $repo"
        broken=1
      fi
    done < <(find "$p_dir" -maxdepth 3 -type d -name .git 2>/dev/null)
    if [ "$broken" -eq 1 ]; then
      echo "  move them into another persona's dir and run 'hat adopt' there first."
    fi
    echo "⚠ repos left under $p_dir will fall back to the default (personal) identity."
  fi

  local ans
  read -rp "Delete persona '$name'? [y/N] " ans || ans=""
  if [[ ! "$ans" =~ ^[Yy]$ ]]; then
    echo "Aborted."
    return 1
  fi

  rm -f "$PERSONAS_DIR/$name.conf"
  echo "✔ removed $name.conf"
  cmd_sync

  # ключ — отдельное явное согласие; pubkey на GitHub в любом случае остаётся
  if [ -f "$p_key" ]; then
    read -rp "Delete SSH key pair $p_key (+.pub)? [y/N] " ans || ans=""
    if [[ "$ans" =~ ^[Yy]$ ]]; then
      rm -f "$p_key" "$p_key.pub"
      echo "✔ key deleted locally; the public key on GitHub is NOT removed —"
      echo "  revoke it there: gh ssh-key delete (or https://github.com/settings/keys)"
    else
      echo "Key kept: $p_key"
    fi
  fi
}

# parse_org_repo <url> — печатает 'org/repo' из любого формата URL
# (scp: git@host:org/repo.git, https://host/org/repo, ssh://git@host/org/repo).
parse_org_repo() {
  local path="${1%.git}"       # убрать хвостовой .git
  path="${path#*://}"          # убрать схему https:// / ssh:// если есть
  path="${path#*@}"            # убрать user@ если есть
  path="${path#*[:/]}"         # убрать host + первый ':' или '/'

  if [[ ! "$path" =~ ^[^/]+/[^/]+$ ]]; then
    return 1
  fi
  echo "$path"
}

# url_host <url> — печатает host из URL (часть до первого ':' или '/')
url_host() {
  local h="${1#*://}"   # убрать схему
  h="${h#*@}"           # убрать user@
  echo "${h%%[:/]*}"    # оставить только host
}

# cmd_clone <git-url> — клонирует репозиторий в $PWD под персоной текущей папки.
# Принимает и scp-форму (git@github.com:org/repo.git), и https-форму.
cmd_clone() {
  local url="${1:-}"
  if [ -z "$url" ]; then
    echo "Usage: git-hat clone <git-url>" >&2
    return 1
  fi

  # 1. персона по текущей директории
  local persona
  if ! persona=$(persona_for_path "$PWD"); then
    echo "No persona for current directory: $PWD" >&2
    echo "cd into a persona directory first (see 'git-hat whoami')." >&2
    return 1
  fi

  # 2. вытащить org/repo из любого формата URL
  local path
  if ! path=$(parse_org_repo "$url"); then
    echo "Cannot parse 'org/repo' from URL: $url" >&2
    return 1
  fi

  # 3. проверить, что папка назначения свободна
  local repo="${path##*/}"
  if [ -e "$PWD/$repo" ]; then
    echo "Target already exists: $PWD/$repo" >&2
    return 1
  fi

  # 4. переписать хост на алиас персоны и клонировать
  local new_url="git@github-${persona}:${path}.git"
  echo "Cloning as '$persona': $new_url"
  git clone "$new_url"
}

# cmd_remote_add <git-url> [remote-name] — добавляет remote текущему репозиторию
# под алиасом персоны его каталога (remote-name по умолчанию 'origin').
# Закрывает сценарий "уже есть локальный репо + свежесозданный GitHub-репо":
# GitHub советует `git remote add origin git@github.com:org/repo.git`, а тут
# host сразу правильный (github-<persona>) — без последующего `hat adopt`.
# Принимает и scp-форму (git@github.com:org/repo.git), и https-форму.
cmd_remote_add() {
  local url="${1:-}"
  local remote="${2:-origin}"

  if [ -z "$url" ]; then
    echo "Usage: git-hat remote-add <git-url> [remote-name]" >&2
    return 1
  fi

  # 1. корень репозитория
  local top
  if ! top=$(git rev-parse --show-toplevel 2>/dev/null); then
    echo "Not inside a git repository: $PWD" >&2
    return 1
  fi

  # 2. персона по каталогу репозитория
  local persona
  if ! persona=$(persona_for_path "$top"); then
    echo "No persona for repository: $top" >&2
    echo "Move the repo into a persona directory first (see 'git-hat whoami')." >&2
    return 1
  fi

  # 3. remote с таким именем не должен уже существовать
  if git remote get-url "$remote" >/dev/null 2>&1; then
    echo "Remote '$remote' already exists: $(git remote get-url "$remote")" >&2
    echo "Use 'git-hat adopt' to rewrite existing remotes." >&2
    return 1
  fi

  # 4. вытащить org/repo из любого формата URL
  local path
  if ! path=$(parse_org_repo "$url"); then
    echo "Cannot parse 'org/repo' from URL: $url" >&2
    return 1
  fi

  # 5. добавить remote под алиасом персоны
  local new_url="git@github-${persona}:${path}.git"
  git remote add "$remote" "$new_url"
  echo "✔ $remote → $new_url"
  echo "Added as '$persona' (identity: $(git -C "$top" config user.email))"
}

# cmd_adopt — переписывает GitHub-remote'ы текущего репозитория на алиас
# персоны его каталога: github.com и чужие github-<persona> → github-<своя>.
# Чинит репозитории, заведённые мимо `hat clone` (git clone / git remote add).
# Не-GitHub remote'ы (gitlab и т.п.) не трогает.
cmd_adopt() {
  # 1. корень репозитория
  local top
  if ! top=$(git rev-parse --show-toplevel 2>/dev/null); then
    echo "Not inside a git repository: $PWD" >&2
    return 1
  fi

  # 2. персона по каталогу репозитория
  local persona
  if ! persona=$(persona_for_path "$top"); then
    echo "No persona for repository: $top" >&2
    echo "Move the repo into a persona directory first (see 'git-hat whoami')." >&2
    return 1
  fi

  # 3. пройтись по remote'ам и переписать GitHub-хосты
  local remotes
  remotes=$(git remote)
  if [ -z "$remotes" ]; then
    echo "No remotes in $top" >&2
    return 1
  fi

  local r url host path new_url
  for r in $remotes; do
    url=$(git remote get-url "$r")
    host=$(url_host "$url")

    # трогаем только github.com и github-<persona>-алиасы
    if [ "$host" != "github.com" ] && [[ "$host" != github-* ]]; then
      echo "− $r: non-GitHub remote, skipped ($url)"
      continue
    fi

    if [ "$host" = "github-$persona" ]; then
      echo "✔ $r: already correct ($url)"
      continue
    fi

    if ! path=$(parse_org_repo "$url"); then
      echo "✘ $r: cannot parse 'org/repo' from URL: $url" >&2
      return 1
    fi

    new_url="git@github-${persona}:${path}.git"
    git remote set-url "$r" "$new_url"
    echo "✔ $r: $url → $new_url"
  done

  echo "Adopted as '$persona' (identity: $(git -C "$top" config user.email))"
}

# cmd_sync — генерирует ssh_config, gitconfig-<persona> и includeIf-блоки
# из personas/*.conf в подпапку generated/.
cmd_sync() {
  local out="$SCRIPT_DIR/generated"
  mkdir -p "$out"

  local ssh_out="$out/ssh_config"
  local inc_out="$out/gitconfig-includes"
  rm -f "$out"/gitconfig-*   # убрать конфиги удалённых персон (всё derived)
  : > "$ssh_out"      # обнулить файлы перед записью
  : > "$inc_out"

  local name
  for name in $(list_personas); do
    load_persona "$name"

    # создать каталог персоны — includeIf и `hat clone` ожидают его наличие
    mkdir -p "$DIR"

    # предупредить, если приватного ключа ещё нет (sync не блокируем)
    if [ ! -f "$KEY" ]; then
      echo "⚠ $name: key not found: $KEY — run 'hat keygen'" >&2
    fi

    # SSH host-блок: github-<name> → ключ персоны
    cat >> "$ssh_out" <<EOF
Host github-$name
  HostName github.com
  User git
  IdentityFile $KEY
  IdentitiesOnly yes

EOF

    # Персональный gitconfig с identity
    cat > "$out/gitconfig-$name" <<EOF
[user]
	name = $NAME
	email = $EMAIL
EOF

    # includeIf: в каталоге персоны применять её gitconfig
    cat >> "$inc_out" <<EOF
[includeIf "gitdir:$DIR/"]
	path = $out/gitconfig-$name
EOF
  done

  echo "Generated in $out:"
  ls -1 "$out"
}

# cmd_keygen — генерирует отсутствующие ключи персон (ed25519).
# Скачать приватный ключ с GitHub нельзя — там хранятся только публичные;
# поэтому генерируем локально и предлагаем загрузить .pub через gh.
cmd_keygen() {
  local name
  for name in $(list_personas); do
    load_persona "$name"

    if [ -f "$KEY" ]; then
      echo "✔ $name: key exists: $KEY"
      continue
    fi

    echo "── $name: generating $KEY"
    ssh-keygen -t ed25519 -C "$EMAIL" -f "$KEY"

    # Загрузка pubkey — только с явного согласия: gh залогинен в ОДИН аккаунт,
    # а персоны маппятся на разные. Показываем, какой аккаунт активен.
    if command -v gh >/dev/null 2>&1 && gh auth status >/dev/null 2>&1; then
      local active ans
      active=$(gh api user --jq .login 2>/dev/null || echo "unknown")
      read -rp "Upload $KEY.pub to GitHub account '$active'? [y/N] " ans || ans=""
      if [[ "$ans" =~ ^[Yy]$ ]]; then
        if ! gh ssh-key add "$KEY.pub" --title "hat-$name-$(hostname)"; then
          echo "  upload failed — likely missing scope; fix with:" >&2
          echo "  gh auth refresh -h github.com -s admin:public_key" >&2
        fi
      else
        echo "  skipped — upload later (to the RIGHT account, see 'gh auth switch'):"
        echo "  gh ssh-key add $KEY.pub --title hat-$name-$(hostname)"
      fi
    else
      echo "  gh not available/authenticated — add the key manually:"
      echo "  gh ssh-key add $KEY.pub --title hat-$name-$(hostname)"
      echo "  (or paste $KEY.pub at https://github.com/settings/keys)"
    fi
  done
}

# cmd_doctor — проверка готовности машины: gh, generated-конфиги,
# и per persona: каталог, ключ, реальная ssh-аутентификация на GitHub.
cmd_doctor() {
  local fail=0

  # gh нужен для https credential helper из config-files/gitconfig
  if command -v gh >/dev/null 2>&1; then
    if gh auth status >/dev/null 2>&1; then
      echo "✔ gh: installed & authenticated"
    else
      echo "✘ gh: installed, but not authenticated — run 'gh auth login'"
      fail=1
    fi
  else
    echo "✘ gh: not installed — sudo pacman -S github-cli"
    fail=1
  fi

  if [ -f "$SCRIPT_DIR/generated/ssh_config" ]; then
    echo "✔ generated configs present"
  else
    echo "✘ generated configs missing — run 'hat sync'"
    fail=1
  fi

  local name
  for name in $(list_personas); do
    load_persona "$name"
    echo "── $name"

    if [ -d "$DIR" ]; then
      echo "  ✔ dir: $DIR"
    else
      echo "  ✘ dir missing: $DIR — run 'hat sync'"
      fail=1
    fi

    if [ -f "$KEY" ]; then
      echo "  ✔ key: $KEY"
    else
      echo "  ✘ key missing: $KEY — run 'hat keygen'"
      fail=1
      continue   # без ключа ssh-тест бессмыслен
    fi

    # GitHub на `ssh -T` всегда возвращает 1 — успех определяем по тексту ответа
    local out login
    out=$(ssh -T -o BatchMode=yes -o ConnectTimeout=5 \
              -o StrictHostKeyChecking=accept-new "git@github-$name" 2>&1 || true)
    if [[ "$out" == *"successfully authenticated"* ]]; then
      login="${out#Hi }"; login="${login%%!*}"
      echo "  ✔ ssh: authenticated as '$login'"
    else
      echo "  ✘ ssh: auth failed — ${out:-no output}"
      fail=1
    fi
  done

  [ "$fail" -eq 0 ] && echo "All checks passed."
  return "$fail"
}

main() {
  if [ $# -eq 0 ]; then
    usage
    exit 1
  fi

  local cmd="$1"
  shift

  case "$cmd" in
    clone)
      cmd_clone "$@"
      ;;
    remote-add)
      cmd_remote_add "$@"
      ;;
    adopt)
      cmd_adopt "$@"
      ;;
    whoami)
      cmd_whoami "$@"
      ;;
    add)
      cmd_add "$@"
      ;;
    remove)
      cmd_remove "$@"
      ;;
    sync)
      cmd_sync "$@"
      ;;
    keygen)
      cmd_keygen "$@"
      ;;
    doctor)
      cmd_doctor "$@"
      ;;
    *)
      usage
      exit 1
      ;;
  esac
  
}

main "$@"
